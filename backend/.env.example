# Copy this file to .env and fill in your values
DATABASE_URL=mysql+mysqlconnector://root:yourpassword@localhost:3306/healthcare_ai
SECRET_KEY=change-this-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Scraper DB – defaults to same host/credentials as DATABASE_URL but uses
# the MY_CUSTOM_BOT database (auto-derived if not set explicitly)
# SCRAPER_DATABASE_URL=mysql+mysqlconnector://root:yourpassword@localhost:3306/MY_CUSTOM_BOT
